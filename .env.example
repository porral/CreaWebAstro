# Postgres connection string. When running via `docker compose`, the host
# must match the `postgres` service name; for local `npm run dev` against a
# host Postgres, use `localhost`.
DATABASE_URL="postgres://astroforge:astroforge@localhost:5432/astroforge"

# Postgres credentials used by the docker-compose `postgres` service itself.
POSTGRES_USER="astroforge"
POSTGRES_PASSWORD="change-me"
POSTGRES_DB="astroforge"

# Secret used to sign session JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-string"

# OpenAI API key, used for site-plan generation (GPT-4o) and image
# generation (gpt-image-1).
OPENAI_API_KEY=""

# Directory where generated site images are stored on disk.
UPLOADS_DIR="/data/uploads"

# Port the app listens on.
PORT="3000"

NODE_ENV="production"

# Number of Node worker processes (one per CPU core if unset, capped at 4).
# The app runs clustered so a slow AI request in one worker never blocks
# requests handled by another.
# WEB_CONCURRENCY="4"
